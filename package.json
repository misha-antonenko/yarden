{
	"name": "yarden-theme",
	"displayName": "Yarden Theme",
	"description": "Monochrome stone-colored theme with minimal highlighting",
	"version": "1.0.2",
	"publisher": "mshntnnk",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/misha-antonenko/yarden.git"
	},
	"engines": {
		"vscode": "^1.11.0"
	},
	"galleryBanner": {
		"color": "#161821",
		"theme": "dark"
	},
	"categories": [
		"Themes"
	],
	"contributes": {
		"themes": [
			{
				"label": "Yarden",
				"uiTheme": "vs-dark",
				"path": "./themes/yarden.color-theme.json"
			},
			{
				"label": "Yarden Light",
				"uiTheme": "vs",
				"path": "./themes/yarden-light.color-theme.json"
			}
		]
	},
	"scripts": {
		"test": "npm run lint",
		"build": "tsc --build src/tsconfig.json && node tmp/main.js",
		"format": "eslint --config src/.eslintrc.js --ext .ts --fix 'src/**/*.ts'",
		"lint": "eslint --config src/.eslintrc.js --ext .ts 'src/**/*.ts'",
		"watch": "onchange --initial --kill \"src/**/*.ts\" -- npm run build"
	},
	"devDependencies": {
		"@types/chroma-js": "^2.1.2",
		"@types/node": "^14.14.14",
		"@typescript-eslint/eslint-plugin": "^4.10.0",
		"@typescript-eslint/parser": "^4.10.0",
		"chroma-js": "^2.1.0",
		"eslint": "^7.16.0",
		"eslint-config-prettier": "^7.1.0",
		"eslint-plugin-prettier": "^3.3.0",
		"onchange": "^7.1.0",
		"prettier": "^2.2.1",
		"typescript": "^4.1.3"
	}
}
